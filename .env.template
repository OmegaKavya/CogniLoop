# Flask Secret Key
SECRET_KEY=your_production_secret_key_here

# Ollama Endpoint (used as fallback if GROQ_API_KEY is not set)
OLLAMA_URL=http://localhost:11434/api/generate

# Groq API Key — FREE at https://console.groq.com (no credit card needed)
# When set, Groq is used as the primary LLM (quiz generates in ~2s vs ~90s with Ollama)
GROQ_API_KEY=

# Deployment Environment
FLASK_ENV=development
